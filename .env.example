# TeleVault — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Telegram API credentials ─────────────────────────────────────────────────
# Get these from https://my.telegram.org → "API development tools"
TG_API_ID=
TG_API_HASH=
TG_PHONE=          # International format, e.g. +1234567890

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file. Created automatically on first run.
DB_PATH=data/televault.db

# Telethon saves your login session here as <SESSION_NAME>.session
# Change this only if you need multiple concurrent sessions (unusual).
SESSION_NAME=televault

# ── Logging ───────────────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Leave blank to log to console only (handy during local development).
# Set a path (e.g. logs/televault.log) to also write rotating log files.
LOG_FILE=